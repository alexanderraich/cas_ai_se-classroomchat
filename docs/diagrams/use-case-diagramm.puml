@startuml ClassroomChat-UseCases
title Classroom Chat — Use-Case-Übersicht (Schritt 2/3)

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Gast" as Gast
actor "Eingeloggter Benutzer" as Benutzer
actor "Gruppen-Eigentümer" as Eigentuemer

' Vererbung: Eigentümer ist auch Benutzer; Benutzer war einmal Gast
Benutzer  --|> Gast
Eigentuemer --|> Benutzer

rectangle "Classroom Chat" {
  usecase "UC-1\nApp betreten &\nAnzeigename festlegen" as UC1
  usecase "UC-2\nGruppe erstellen"               as UC2
  usecase "UC-3\nGruppe umbenennen"              as UC3
  usecase "UC-6\nGruppe löschen"                 as UC6
  usecase "UC-7\nGruppe auswählen"               as UC7
  usecase "UC-8\nNachricht senden"               as UC8
  usecase "UC-9\nLive-Updates empfangen"         as UC9
}

Gast        --> UC1

Benutzer    --> UC2
Benutzer    --> UC7
Benutzer    --> UC8
Benutzer    --> UC9

Eigentuemer --> UC3
Eigentuemer --> UC6

' Inklusionsbeziehung: Gruppe erstellen setzt Anzeigename voraus
UC2  ..> UC1 : <<include>>

@enduml
